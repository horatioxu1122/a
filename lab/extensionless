#if 0
# ── extensionless — a file with no extension that self-compiles as C ──
#
# WHAT THIS DEMONSTRATES:
# A single file with no extension can be valid sh AND valid C simultaneously.
# sh extensionless    → runs shell block, compiles itself, runs binary
# cc -x c extensionless -o /tmp/extensionless && /tmp/extensionless  → manual
#
# WHY NO EXTENSION WORKS:
# - sh doesn't care about extensions, reads content
# - cc needs -x c to know it's C (or some compilers guess from #include)
# - The #if 0 / #endif polyglot trick works identically
#
# WHAT YOU GAIN:
# - Language-independent identity: rewrite in any lang, name never changes
# - The file IS the command name — "extensionless" not "extensionless.c"
# - curl https://example.com/extensionless | sh  works (no .c confusion)
#
# WHAT YOU LOSE:
# - LLMs can't identify language without reading content
# - Editors default to plaintext (no syntax highlighting)
# - GitHub/tools won't auto-detect language
# - cc requires explicit -x c flag
#
# VERDICT: a.c keeps .c because LLM legibility > 2 chars saved

[ -z "$BASH_VERSION" ] && exec bash "$0" "$@"
set -e
D="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BIN="/tmp/extensionless_bin"

CC=cc
# extensionless files need -x c to tell compiler it's C
$CC -x c -O2 -o "$BIN" "$0" 2>/dev/null && {
    echo "✓ compiled extensionless file as C"
    "$BIN"
    rm -f "$BIN"
    exit 0
}
echo "✗ compile failed"
exit 1
#endif

#include <stdio.h>
int main(void) {
    puts("hello from a file with no extension, compiled as C");
    return 0;
}
